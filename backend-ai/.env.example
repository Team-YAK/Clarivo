# ─── backend-ai environment template ───────────────────────────────────────
# Copy this file to .env and fill in your values. Never commit the real .env.

# ─── AI Service (REQUIRED FOR LIVE AI) ───────────────────────────────────
# OpenAI — used for intent generation and tree expansion
# If you don't have a key, set USE_MOCK=true below
OPENAI_API_KEY=your_openai_key_here
MODEL_NAME=gpt-4o-mini

# ─── Voice Synthesis (OPTIONAL) ──────────────────────────────────────────
# ElevenLabs — used for TTS voice output
ELEVENLABS_API_KEY=your_elevenlabs_key_here
YUKI_VOICE_ID=your_voice_id_here

# ─── Service Integration ─────────────────────────────────────────
# URL of the backend-data service (E3)
E3_BASE_URL=http://localhost:8002

# ─── File Storage ───────────────────────────────────────────────
# Where to save generated audio files (e.g. ./audio_output)
AUDIO_OUTPUT_DIR=audio_output

# ─── Offline Mode ────────────────────────────────────────────────
# Set to true to skip real AI calls and return mock data
# This allows the app to work without any API keys!
USE_MOCK=true

# ─── Server ──────────────────────────────────────────────────────
PORT=8001
CLARIVO_RELOAD=true
