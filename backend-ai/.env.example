# ─── backend-ai environment template ───────────────────────────────────────
# Copy this file to .env and fill in your values. Never commit the real .env.

# ─── LLM Configuration ──────────────────────────────────────────
# OpenAI — used by the 4-agent navigation pipeline and intent generation
OPENAI_API_KEY=your_openai_key_here
MODEL_NAME=gpt-4o-mini

# ─── Voice Synthesis ─────────────────────────────────────────────
# ElevenLabs — used for TTS voice output
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Voice ID from your ElevenLabs dashboard
YUKI_VOICE_ID=your_voice_id_here

# ─── Service Integration ─────────────────────────────────────────
# URL of the backend-data service (leave default for local dev)
E3_BASE_URL=http://localhost:8002
DATA_BACKEND_URL=http://localhost:8002

# ─── Database ────────────────────────────────────────────────────
# MongoDB Atlas connection string OR local instance
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/

# Set to true to skip real AI/DB calls and return mock data (offline dev)
USE_MOCK=false

# ─── Server ──────────────────────────────────────────────────────
PORT=8001
