# ─── backend-data environment template ─────────────────────────────────────
# Copy this file to .env and fill in your values. Never commit the real .env.

# ─── LLM Configuration ──────────────────────────────────────────
# OpenAI — used for patient context and session processing
OPENAI_API_KEY=your_openai_key_here

# ─── Voice Synthesis ─────────────────────────────────────────────
# ElevenLabs — used for TTS voice output
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Voice ID from your ElevenLabs dashboard
YUKI_VOICE_ID=your_voice_id_here

# ─── Database ────────────────────────────────────────────────────
# MongoDB Atlas connection string OR local instance
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
DB_NAME=voicemap

# Set to true to use in-memory mock instead of real MongoDB (offline dev)
USE_MOCK_DB=true

# ─── Server ──────────────────────────────────────────────────────
PORT=8002
CLARIVO_RELOAD=true
