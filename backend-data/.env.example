# ─── backend-data environment template ─────────────────────────────────────
# Copy this file to .env and fill in your values. Never commit the real .env.

# ─── AI Configuration (OPTIONAL) ───────────────────────────────────
# OpenAI — used for session summarization and context analysis
OPENAI_API_KEY=your_openai_key_here

# ─── Database ────────────────────────────────────────────────────
# Use a real MongoDB connection string here (Atlas or Local)
# Only used if USE_MOCK_DB=false below
MONGODB_URI=mongodb://localhost:27017
DB_NAME=voicemap

# ─── Offline Mode / Local Dev ─────────────────────────────────────
# Set to true to use an in-memory database (NO MONGODB NEEDED!)
# This is perfect for local development and testing
USE_MOCK_DB=true

# ─── Default User ────────────────────────────────────────────────
DEFAULT_USER_ID=alex_demo

# ─── Admin ───────────────────────────────────────────────────────
# Token required for POST /api/admin/purge-and-reseed
ADMIN_TOKEN=clarivo-admin-2024

# ─── Server ──────────────────────────────────────────────────────
PORT=8002
CLARIVO_RELOAD=true
